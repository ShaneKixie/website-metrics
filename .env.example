# ── Google OAuth Credentials ──────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# ── OAuth Redirect URI ────────────────────────────────────────────────────────
# Railway: https://your-app.railway.app/oauth/callback
# Local:   http://localhost:3000/oauth/callback
# ⚠️  Must also be registered in Google Cloud Console → Credentials → Authorized redirect URIs
OAUTH_REDIRECT_URI=https://your-app.railway.app/oauth/callback

# ── Port (Railway sets this automatically) ────────────────────────────────────
PORT=3000

# ── Token file path (optional override) ──────────────────────────────────────
# Defaults to /data/tokens.json if Railway volume is mounted at /data, else ./tokens.json
# TOKEN_FILE_PATH=/data/tokens.json
